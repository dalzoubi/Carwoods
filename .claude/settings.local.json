{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git stash:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(xargs wc:*)",
      "Bash(xargs grep:*)",
      "Bash(node --test test/**/*.test.mjs)",
      "Bash(git check-ignore *)",
      "Bash(mkdir -p .claude/state)",
      "Bash(touch .claude/state/probe.json)",
      "Bash(rm -rf .claude/state/probe.json)",
      "Bash(npx eslint *)",
      "Bash(echo \"EXIT=$?\")",
      "Read(//tmp/**)"
    ]
  }
}
