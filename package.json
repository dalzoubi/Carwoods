{
  "name": "carwoods",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://carwoods.com",
  "type": "module",
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.3.0",
    "@mui/material": "^6.3.0",
    "@vercel/analytics": "^2.0.1",
    "firebase": "^12.12.0",
    "gh-pages": "^6.2.0",
    "i18next": "^26.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.1.1",
    "styled-components": "^6.1.13",
    "stylis-plugin-rtl": "^2.1.1",
    "web-vitals": "^4.2.4"
  },
  "scripts": {
    "predev": "node scripts/generatePublicIcons.mjs",
    "dev": "vite",
    "dev:portal": "vite --mode portal",
    "dev:portal:local": "powershell -NoProfile -ExecutionPolicy Bypass -File \"scripts/start-local-portal.ps1\"",
    "prestart": "node scripts/generatePublicIcons.mjs",
    "start": "vite",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "update-rental-tiles": "node scripts/fetchHarRentalApplyTiles.mjs",
    "prebuild": "node scripts/fetchHarRentalApplyTiles.mjs && node scripts/generatePublicIcons.mjs",
    "build": "vite build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "build:api": "npm run build --prefix apps/api",
    "build:packages": "npm run build --prefix packages/domain && npm run build --prefix packages/config"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "plugin:jsx-a11y/recommended"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "vite": "^7.3.2",
    "undici": "^7.24.0",
    "rollup": "^4.59.0",
    "minimatch": "^3.1.3",
    "picomatch": "^4.0.4",
    "babel-plugin-macros": {
      "cosmiconfig": {
        "yaml": "^1.10.3"
      }
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^7.0.3",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jest-axe": "^9.0.0",
    "jsdom": "^28.1.0",
    "png-to-ico": "^3.0.1",
    "serve": "^14.2.4",
    "sharp": "^0.34.5",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  }
}
