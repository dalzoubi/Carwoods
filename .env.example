# Public Vite variables only — never put secrets here.
# See docs/portal/ENV_CONTRACT.md for full list including API.

# VITE_API_BASE_URL=https://your-api.azurewebsites.net
# When URL is set, /apply loads tiles from GET /api/public/apply-properties (Step 3).
# Opt out with: VITE_FEATURE_APPLY_API=false
# VITE_FEATURE_APPLY_API=
# Dev: compare API vs generated file in console (Step 2). Silence with VITE_FEATURE_APPLY_DUAL_SOURCE=false
# VITE_FEATURE_APPLY_DUAL_SOURCE=
# VITE_ENTRA_CLIENT_ID=
# VITE_ENTRA_AUTHORITY=
# VITE_ENTRA_API_SCOPE=

# Local dev (optional)
# CHOKIDAR_USEPOLLING=true
