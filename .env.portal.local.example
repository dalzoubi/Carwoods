# Vite --mode portal (npm run dev:portal). Gitignored copy: .env.portal.local
#
# Pair with apps/api/local.settings.json (from local.settings.json.example):
#   VITE_ENTRA_AUTHORITY must match ENTRA_ISSUER; the api://… id in VITE_ENTRA_API_SCOPE
#   matches ENTRA_API_AUDIENCE. Full list: docs/portal/ENV_CONTRACT.md

CHOKIDAR_USEPOLLING=true
CHOKIDAR_INTERVAL=500
VITE_API_BASE_URL=http://localhost:7071
VITE_ENTRA_CLIENT_ID=your-spa-client-id
VITE_ENTRA_AUTHORITY=https://your-tenant.ciamlogin.com/your-tenant-id/v2.0
VITE_ENTRA_API_SCOPE=api://your-api-app-client-id/access_as_user
