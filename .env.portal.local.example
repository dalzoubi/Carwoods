# Vite --mode portal (npm run dev:portal). Gitignored copy: .env.portal.local
#
# Pair with apps/api/local.settings.json (from local.settings.json.example):
#   VITE_FIREBASE_PROJECT_ID must match FIREBASE_PROJECT_ID.
#   Full list: docs/portal/ENV_CONTRACT.md

CHOKIDAR_USEPOLLING=true
CHOKIDAR_INTERVAL=500
VITE_API_BASE_URL=http://localhost:7071
VITE_NOTIFICATIONS_POLL_MS=60000
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
