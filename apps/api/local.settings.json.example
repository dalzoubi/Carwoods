{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "DefaultEndpointsProtocol=https;AccountName=<storage-account-name>;AccountKey=<storage-account-key>;EndpointSuffix=core.windows.net",
    "FUNCTIONS_WORKER_RUNTIME": "node",
    "AZURE_RESOURCE_GROUP": "carwoods.com",

    "DATABASE_URL": "Server=localhost,1433;Database=carwoods_portal_dev;User Id=sa;Password=<your-local-sa-password>;Encrypt=yes;TrustServerCertificate=yes",

    "CORS_ALLOWED_ORIGINS": "http://localhost:3000,http://127.0.0.1:3000,https://carwoods.com,https://www.carwoods.com",

    "FIREBASE_PROJECT_ID": "your-firebase-project-id",
    "FIREBASE_OPENID_METADATA_URL": "",

    "GEMINI_API_KEY": "<your-gemini-api-key>",

    "AZURE_STORAGE_ACCOUNT_NAME": "<storage-account-name>",
    "AZURE_STORAGE_ACCOUNT_KEY": "<storage-account-key>",
    "AZURE_STORAGE_CONTAINER_NAME": "carwoods-portal-dev",

    "DOCUMENT_STORAGE_CONTAINER_NAME": "carwoods-documents-dev",
    "DOCUMENT_CENTER_ENABLED": "true",
    "DOCUMENT_CENTER_SCAN_BYPASS": "true",

    "RESEND_API_KEY": "re_<your-resend-api-key>",
    "RESEND_EMAIL_FROM": "Carwoods <noreply@carwoods.com>",

    "TELNYX_API_KEY": "KEY<your-telnyx-api-key>",
    "TELNYX_SMS_FROM": "",
    "TELNYX_MESSAGING_PROFILE_ID": "",

    "NOTIFICATION_CHANNELS": "both",

    "PORTAL_LINK_SIGNING_SECRET": "",
    "NOTIFICATION_LINK_SIGNING_SECRET": "",

    "INBOUND_EMAIL_INGEST_SECRET": "",
    "INBOUND_EMAIL_REPLY_LOCAL_PREFIX": "cwreply",

    "NOTIFICATION_OUTBOX_TIMER_DISABLED": "true",
    "NOTIFICATION_OUTBOX_TIMER_CRON": "0 */1 * * * *",
    "NOTIFICATION_OUTBOX_TIMER_BATCH_LIMIT": "25",

    "NOTIFICATION_DELIVERY_TIMER_DISABLED": "true",
    "NOTIFICATION_DELIVERY_TIMER_CRON": "0 */1 * * * *",
    "NOTIFICATION_DELIVERY_TIMER_BATCH_LIMIT": "50",

    "REQUEST_ATTACHMENT_STORAGE_PREFIX": ""
  }
}
